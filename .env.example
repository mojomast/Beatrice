# Copy to .env and set your OpenRouter API key before running.
# Most bot settings can be edited in bot/settings.json.

# Optional at startup; you can set it later in IRC with:
# !bot set openrouter_key <your-key> beans
# OPENROUTER_API_KEY=

BOT_SETTINGS_FILE=bot/settings.json
BOT_RUNTIME_FILE=data/beatrice_runtime.json
BOT_MEMORY_DB_FILE=data/beatrice_memory.sqlite3
BOT_AUDIT_LOG_FILE=data/beatrice_audit.jsonl

IRC_SERVER=irc.ussyco.de
IRC_PORT=6667
IRC_NICK=Beatrice
IRC_USER=beatrice
IRC_REALNAME=Beatrice OpenRouter IRC Bot
IRC_CHANNEL=#ussycode

BOT_COMMAND_PREFIX=!bot
BOT_ADMIN_PASSWORD=beans
# Optional comma-separated nicks allowed to approve dangerous autonomous actions.
# BOT_ADMIN_NICKS=yourNick
# BOT_APPROVAL_TIMEOUT_SECONDS=900

# Optional server password for IRC registration.
# IRC_PASSWORD=

# Optional OpenRouter metadata headers.
# OPENROUTER_HTTP_REFERER=https://example.com
# OPENROUTER_TITLE=Beatrice IRC Bot
